generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenancy root ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users             OrganizationUser[]
  pipelines         Pipeline[]
  contacts          Contact[]
  deals             Deal[]
  tasks             Task[]
  activities        Activity[]
  lossReasons       LossReason[]
  teams             Team[]
  automationRules   AutomationRule[]
  whatsappInstances WhatsAppInstance[]
  whatsappThreads   WhatsAppThread[]
  whatsappMessages  WhatsAppMessage[]
  campaigns         Campaign[]
  messageScripts    MessageScript[]
}

// ─── Usuários ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  accounts                 Account[]
  sessions                 Session[]
  orgs                     OrganizationUser[]
  dealsOwned               Deal[]
  tasksOwned               Task[]
  activities               Activity[]
  teamsLed                 Team[]                     @relation("TeamLeader")
  teamsManaged             Team[]                     @relation("TeamManager")
  pushSubscriptions        PushSubscription[]
  whatsappInstances        WhatsAppInstance[]
  campaignsCreated         Campaign[]
  messageScripts           MessageScript[]
  googleCalendarConnection GoogleCalendarConnection?
}

// ─── Google Agenda (OAuth por usuário) ───────────────────────────────
//
// Um client OAuth só (client id/secret nas env vars) serve o app inteiro;
// cada usuário conecta a PRÓPRIA conta Google aqui, um por um — mesmo
// espírito do WhatsAppInstance (um número por vendedor, nunca compartilhado).

model GoogleCalendarConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  // E-mail da conta Google conectada — só pra mostrar "conectado como
  // fulano@gmail.com" na tela de perfil, nunca usado pra autenticar nada.
  calendarEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notificações push (Web Push) ───────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── WhatsApp (Evolution API) ───────────────────────────────────────
//
// Uma instância (número de WhatsApp) por vendedor — nunca por organização
// inteira, pra não depender de um único número compartilhado. `instanceName`
// é o identificador que o Evolution API usa; nunca exposto ao frontend fora
// do necessário pra exibir o QR Code de pareamento.

model WhatsAppInstance {
  id                     String                 @id @default(cuid())
  organizationId         String
  userId                 String
  instanceName           String                 @unique
  phoneNumber            String?
  status                 WhatsAppInstanceStatus @default(DISCONNECTED)
  // Quando ficou desconectado pela primeira vez nesta "queda" (null quando
  // conectado) — usado pra escalar o alerta por e-mail (1, 2, 3 dias). Zera
  // quando reconecta.
  disconnectedAt         DateTime?
  // Até qual nível de alerta já mandamos nesta queda: 0 = só o aviso
  // imediato, 1/2/3 = já mandou o de 1/2/3 dias. Nunca passa de 3 — "chega
  // de falar" depois disso.
  disconnectAlertLevel   Int                    @default(0)
  // Marca quando o cron de saúde viu pela 1ª vez um estado != "open" numa
  // instância que achávamos CONNECTED — só confirma a queda de verdade (e
  // avisa por e-mail) se isso persistir até a PRÓXIMA rodada. O Evolution às
  // vezes reporta um estado errado passageiro; sem essa confirmação, cada
  // soluço falso virava um e-mail de "desconectou" + outro de "conectou"
  // logo em seguida, um par de spam por rodada de cron.
  pendingDisconnectSince DateTime?
  // Liga/desliga separadamente o push de mensagem nova pra conversas
  // vinculadas a um Contact (CRM) e pras avulsas (Geral) — dá pra silenciar
  // o ruído do Geral sem perder aviso de lead de verdade, ou vice-versa.
  notifyOnCrmMessage     Boolean                @default(true)
  notifyOnGeralMessage   Boolean                @default(true)
  // Marcado depois de importar o histórico (evento MESSAGES_SET, disparado
  // pelo Evolution só na 1ª sincronização após escanear o QR Code) — garante
  // que a importação roda uma única vez por pareamento, nunca de novo à toa
  // a cada webhook repetido. Instâncias que já existiam antes desse recurso
  // nunca disparam esse evento de novo sozinhas, então nunca são afetadas.
  historySyncedAt        DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads      WhatsAppThread[]
  messages     WhatsAppMessage[]
  campaigns    Campaign[]

  @@unique([organizationId, userId])
  @@index([organizationId])
}

enum WhatsAppInstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

// Uma "conversa" existe por si só — não depende de um Contact do CRM já
// cadastrado. Toda mensagem (recebida ou enviada) sempre pertence a uma
// thread; o Contact é um vínculo opcional que aparece quando o número bate
// com um já cadastrado (na hora ou depois, promovendo a conversa pra aba
// "WhatsApp CRM" — ver lib/whatsapp/threads.ts).
model WhatsAppThread {
  id              String  @id @default(cuid())
  organizationId  String
  instanceId      String
  phoneNormalized String // número normalizado da OUTRA parte, nunca da nossa instância
  whatsappName    String? // pushName do WhatsApp — melhor-esforço, pode ficar desatualizado
  contactId       String?

  // Foto de perfil do WhatsApp do contato — cacheada aqui pra não bater no
  // Evolution API toda vez que o chat abre (ver app/api/whatsapp/threads/
  // [threadId]/photo). null também é cache válido: contato pode não ter foto
  // ou ter privacidade restrita; profilePicFetchedAt marca a última tentativa.
  profilePicUrl       String?
  profilePicFetchedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instance           WhatsAppInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  contact            Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages           WhatsAppMessage[]
  campaignRecipients CampaignRecipient[]

  @@unique([instanceId, phoneNormalized])
  @@index([organizationId, contactId])
  @@index([organizationId])
}

model WhatsAppMessage {
  id             String                   @id @default(cuid())
  organizationId String
  instanceId     String
  threadId       String
  direction      WhatsAppMessageDirection
  type           WhatsAppMessageType      @default(TEXT)
  body           String?
  mediaUrl       String?
  metadata       Json?
  status         WhatsAppMessageStatus    @default(PENDING)
  externalId     String?                  @unique
  // Só é relevante pra mensagens INBOUND — vira true quando o chat daquela
  // conversa é aberto (GET /api/whatsapp/messages/[threadId]). Alimenta o
  // sinal de "lead respondeu" no card do negócio.
  read           Boolean                  @default(false)
  // { key, message } no formato bruto do WhatsApp/Baileys — é o que o
  // Evolution exige no campo "quoted" pra responder a esta mensagem depois
  // (tanto em mensagens recebidas quanto nas que a gente manda).
  rawPayload     Json?
  replyToId      String?
  // Marca esta mensagem (só as OUTBOUND que o motor de campanhas manda) como
  // vinda de um disparo de lista fria — indicador de primeira classe, em vez
  // de tentar adivinhar "isso parece uma campanha" comparando texto/horário
  // depois. Sem isso, os relatórios (app/(dashboard)/relatorios/page.tsx)
  // contavam qualquer mensagem enviada (conversa manual, automação) junto
  // com prospecção fria nas mesmas métricas gerais.
  campaignId     String?
  createdAt      DateTime                 @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instance     WhatsAppInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  thread       WhatsAppThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  replyTo      WhatsAppMessage?  @relation("WhatsAppMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      WhatsAppMessage[] @relation("WhatsAppMessageReplies")
  campaign     Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([organizationId, threadId, createdAt])
  @@index([organizationId, instanceId])
  @@index([organizationId, threadId, direction, read])
  @@index([organizationId, campaignId])
}

enum WhatsAppMessageDirection {
  OUTBOUND
  INBOUND
}

enum WhatsAppMessageType {
  TEXT
  IMAGE
  AUDIO
  CONTACT
  PIX
  BUTTONS
  LIST
  STICKER
  CALL
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ─── Scripts (biblioteca de mensagens reutilizáveis) ────────────────
//
// Salvo uma vez, reaproveitado em quantas campanhas quiser — na criação da
// campanha o texto de cada script escolhido é copiado pro
// Campaign.messageTemplates (snapshot), então editar/apagar um script depois
// nunca muda uma campanha que já estava rodando com ele.

model MessageScript {
  id             String @id @default(cuid())
  organizationId String
  name           String

  // Sequência de mensagens do script (nunca um texto único) — simula uma
  // pessoa mandando várias mensagens curtas em seguida, cada uma com um
  // delay (em segundos) até a próxima:
  // [{ text: "Oi {primeiro_nome}!", delayAfterSec: 2 }, { text: "Tudo bem?", delayAfterSec: 0 }]
  // Suporta spintax `{[a|b|c]}` e variáveis `{nome}`/`{primeiro_nome}`/
  // `{cargo}`/`{empresa}`/`{cidade}`/`{saudacao}` em cada texto.
  steps Json

  // Livre, sem tabela própria — organiza/filtra a biblioteca (ex.: "abertura",
  // "follow-up"), não é uma taxonomia fixa controlada pelo admin.
  tags String[] @default([])

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

// ─── Campanhas de prospecção em massa ───────────────────────────────
//
// Envia pra uma lista de contatos (filtrada uma vez na criação, não uma
// query dinâmica — evita a lista mudar no meio do disparo) usando o próprio
// motor de WhatsApp do CRM (WhatsAppThread/WhatsAppMessage via Evolution),
// nunca um serviço externo. Um cron dedicado (lib/campaigns/engine.ts) manda
// no máximo uma mensagem por campanha a cada execução, respeitando o delay
// configurado — não é um worker próprio rodando timers em memória.

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  status         CampaignStatus @default(DRAFT)

  // Variantes de mensagem (snapshot do script na hora da criação, nunca
  // reconsultado depois): [{ steps: [{text, delayAfterSec}], weight: 1,
  // scriptId: "..." }, ...]. scriptId é só referência pra exibição ("onde
  // esse script é usado") — apagar/editar o script original não afeta isso.
  messageTemplates Json

  // Filtro usado pra montar a lista na criação — guardado só pra referência
  // (auditoria/exibição/reedição em rascunho), não é reconsultado
  // automaticamente depois: os destinatários reais são as linhas de
  // CampaignRecipient já materializadas.
  // { jobTitles: string[], tags: string[], cities: string[] } — cada lista é
  // um OR entre si, listas diferentes são AND entre si; lista vazia = não
  // filtra por esse critério.
  audienceFilter Json

  instanceId String // De qual WhatsApp conectado a campanha dispara

  delayMinSec Int  @default(30)
  delayMaxSec Int  @default(90)
  dailyCap    Int? // null = sem teto

  // Janela de envio em horário de Brasília — 0=domingo…6=sábado.
  allowedWeekdays Int[] @default([1, 2, 3, 4, 5])
  windowStartHour Int   @default(9)
  windowEndHour   Int   @default(18)

  // Reenvio automático (remarketing) pra quem não respondeu — só UM reenvio
  // por destinatário, nunca uma sequência de várias tentativas. Se
  // followUpTemplates for null, reaproveita messageTemplates no reenvio.
  followUpEnabled    Boolean @default(false)
  followUpDelayHours Int     @default(24)
  followUpTemplates  Json?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  instance     WhatsAppInstance    @relation(fields: [instanceId], references: [id])
  createdBy    User                @relation(fields: [createdById], references: [id])
  recipients   CampaignRecipient[]
  messages     WhatsAppMessage[]

  @@index([organizationId])
  @@index([organizationId, status])
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  DONE
}

model CampaignRecipient {
  id         String                  @id @default(cuid())
  campaignId String
  contactId  String
  status     CampaignRecipientStatus @default(PENDING)

  threadId         String? // Setado quando enviado — a conversa segue normal em Conversas dali pra frente.
  sentAt           DateTime?
  error            String?
  // Qual script (dentro do snapshot messageTemplates/followUpTemplates) foi
  // de fato sorteado pra esse destinatário — alimenta a quebra por script
  // nos relatórios de prospecção fria. Campos separados porque o envio
  // inicial e o reenvio são eventos distintos, cada um pode ter sorteado um
  // script diferente (mesmo padrão de sentAt/followUpSentAt).
  scriptId         String?
  followUpScriptId String?

  repliedAt DateTime? // Marcado pelo webhook de mensagem recebida (lib/whatsapp/events.ts).

  // Reenvio automático (remarketing) — followUpSentAt marca que já TENTOU
  // (sucesso ou falha, ver followUpError), nunca fica null de novo depois de
  // tentado, pra não reenviar em loop a cada tick do cron.
  followUpSentAt DateTime?
  followUpError  String?

  createdAt DateTime @default(now())

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  thread   WhatsAppThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([threadId])
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model OrganizationUser {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  teamId         String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([teamId])
}

enum OrgRole {
  OWNER
  MANAGER
  SUPERVISOR
  MEMBER
}

// ─── Equipes ─────────────────────────────────────────────────────────

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // Líder = papel SUPERVISOR, gerencia só esta equipe (ver getDealScope).
  leaderId       String?
  // Gerente = papel MANAGER, pode supervisionar várias equipes ao mesmo
  // tempo (um User pode aparecer em teamsManaged de N Teams diferentes).
  managerId      String?
  createdAt      DateTime @default(now())

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leader       User?              @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  manager      User?              @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)
  members      OrganizationUser[]

  @@index([organizationId])
  // Usado por getDealScope (lib/team-scope.ts) — passa a rodar em toda
  // requisição de API de negócios/tarefas (não só em carregamento de página),
  // então precisa ser indexado, não só o organizationId sozinho.
  @@index([organizationId, leaderId])
  @@index([organizationId, managerId])
}

// ─── Auth.js (NextAuth v5) ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Pipeline (Funil) ────────────────────────────────────────────────

model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@index([organizationId])
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  order      Int
  color      String?
  createdAt  DateTime @default(now())

  // Definido pelo admin por etapa (não pela posição): quais campos do
  // Deal precisam estar preenchidos pra um negócio poder entrar/permanecer
  // nesta etapa (ver lib/deal-required-fields.ts pra lista de campos
  // elegíveis). Etapas de nutrição (ex.: Remarketing) tipicamente ficam
  // vazias aqui — lead ainda frio, nada comprometido ainda.
  requiredFields String[] @default([])

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId, order])
}

// ─── Contatos ────────────────────────────────────────────────────────

model Contact {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  email              String?
  phone              String?
  whatsapp           String?
  phoneNormalized    String?
  whatsappNormalized String?
  source             String?
  company            String?
  jobTitle           String?
  address            String?
  addressNumber      String?
  addressComplement  String?
  neighborhood       String?
  city               String?
  state              String?
  zipCode            String?
  tags               String[] @default([])
  createdAt          DateTime @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals              Deal[]
  tasks              Task[]
  activities         Activity[]
  whatsappThreads    WhatsAppThread[]
  campaignRecipients CampaignRecipient[]

  @@unique([organizationId, phoneNormalized])
  @@unique([organizationId, whatsappNormalized])
  @@index([organizationId])
  @@index([organizationId, phone])
}

// ─── Motivos de perda ────────────────────────────────────────────────

model LossReason {
  id             String   @id @default(cuid())
  organizationId String
  label          String
  order          Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId])
}

// ─── Negócio (Deal) ──────────────────────────────────────────────────

model Deal {
  id             String @id @default(cuid())
  organizationId String
  pipelineId     String
  stageId        String
  contactId      String
  ownerId        String

  name   String
  status DealStatus @default(OPEN)

  value Decimal? @db.Decimal(12, 2)

  creditType String?

  startedAt       DateTime  @default(now())
  expectedCloseAt DateTime?
  closedAt        DateTime?
  stageEnteredAt  DateTime  @default(now())

  description  String?
  lossReasonId String?
  lostReason   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  owner        User          @relation(fields: [ownerId], references: [id])
  lossReason   LossReason?   @relation(fields: [lossReasonId], references: [id])
  tasks        Task[]
  activities   Activity[]

  @@index([organizationId, pipelineId, stageId])
  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([organizationId, lossReasonId])
}

enum DealStatus {
  OPEN
  WON
  LOST
}

// ─── Tarefas ─────────────────────────────────────────────────────────

model Task {
  id             String    @id @default(cuid())
  organizationId String
  dealId         String?
  contactId      String?
  ownerId        String
  type           TaskType
  title          String
  description    String?
  dueAt          DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id])
  owner        User         @relation(fields: [ownerId], references: [id])

  @@index([organizationId, ownerId, dueAt])
  @@index([organizationId, dealId])
}

enum TaskType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  VISIT
  PROPOSAL
  NOTE
  OTHER
}

// ─── Histórico de Atividades ─────────────────────────────────────────

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  dealId         String?
  contactId      String?
  userId         String
  type           ActivityType
  body           String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, dealId, createdAt])
}

enum ActivityType {
  NOTE
  EMAIL
  CALL
  WHATSAPP
  PROPOSAL
  MEETING
  VISIT
  // Gerada pelo próprio sistema (mudança de etapa, ganho/perdido, valor) —
  // nunca criada pelo usuário, renderizada como uma linha minimalista na
  // timeline em vez do cartão das atividades manuais.
  SYSTEM
}

// ─── Automações ──────────────────────────────────────────────────────

model AutomationRule {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  trigger        AutomationTrigger
  triggerConfig  Json?
  action         AutomationAction
  actionConfig   Json?
  enabled        Boolean           @default(true)
  runCount       Int               @default(0)
  lastRunAt      DateTime?
  createdAt      DateTime          @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   AutomationExecution[]

  @@index([organizationId])
}

model AutomationExecution {
  id        String   @id @default(cuid())
  ruleId    String
  entityId  String
  createdAt DateTime @default(now())

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, entityId])
}

enum AutomationTrigger {
  DEAL_STALE
  DEAL_CREATED
  DEAL_WON
  DEAL_LOST
  TASK_OVERDUE
  DEAL_STAGE_ENTERED
  DEAL_NO_OPEN_TASK
